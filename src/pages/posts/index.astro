---
import Base from "../../layouts/Base.astro";
import { getCollection } from "astro:content";

const posts = await getCollection("posts", ({ data }) => {
  return import.meta.env.PROD ? !data.draft : true;
});
const sorted = posts.sort(
  (a, b) => new Date(b.data.date).getTime() - new Date(a.data.date).getTime()
);

function postUrl(post: (typeof posts)[0]) {
  const d = new Date(post.data.date);
  const y = d.getFullYear();
  const m = String(d.getMonth() + 1).padStart(2, "0");
  return `/${y}/${m}/${post.id}`;
}
---

<Base title="Posts | ./havu" description="Blog posts">
  <h1 style="font-size: 1.3rem; margin-bottom: 1.5rem;">Posts</h1>
  {sorted.length === 0 && <p style="color: var(--text-muted);">No posts yet.</p>}
  <ul class="post-list">
    {sorted.map((post) => {
      const dateStr = new Date(post.data.date).toISOString().slice(0, 10);
      return (
        <li class="post-item">
          <span class="post-meta">
            <time datetime={dateStr}>{dateStr}</time>
            {post.data.categories?.map((cat) => (
              <span class="badge">{cat}</span>
            ))}
            {post.data.tags?.map((tag) => (
              <span class="badge">{tag}</span>
            ))}
          </span>
          <a class="post-title-link" href={postUrl(post)}>
            {post.data.title}
          </a>
        </li>
      );
    })}
  </ul>
</Base>
