---
import "../styles/global.css";

interface Props {
  title?: string;
  description?: string;
}

const { title = "./havu", description = "Security Researcher" } = Astro.props;
---

<!doctype html>
<html lang="en" data-theme="dark">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="description" content={description} />
    <link rel="alternate" type="application/rss+xml" title="RSS" href="/rss.xml" />
    <title>{title}</title>
    <script is:inline>
      const t = localStorage.getItem("theme") || "dark";
      document.documentElement.setAttribute("data-theme", t);
    </script>
  </head>
  <body>
    <nav>
      <a href="/" class="site-title">./havu</a>
      <div class="nav-right">
        <a href="/posts">Posts</a>
        <a href="/rss.xml">RSS</a>
        <button class="theme-toggle" id="theme-toggle" aria-label="Toggle theme">
          ◐
        </button>
      </div>
    </nav>

    <main>
      <slot />
    </main>

    <footer>
      <p>&copy; {new Date().getFullYear()} havu</p>
    </footer>

    <script is:inline>
      document.getElementById("theme-toggle").addEventListener("click", () => {
        const html = document.documentElement;
        const current = html.getAttribute("data-theme");
        const next = current === "dark" ? "light" : "dark";
        html.setAttribute("data-theme", next);
        localStorage.setItem("theme", next);
        // Sync utterances theme if present
        const frame = document.querySelector(".utterances-frame");
        if (frame) {
          frame.contentWindow.postMessage(
            { type: "set-theme", theme: next === "dark" ? "github-dark" : "github-light" },
            "https://utteranc.es"
          );
        }
      });
    </script>
  </body>
</html>
