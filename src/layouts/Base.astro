---
import "../styles/global.css";

interface Props {
  title?: string;
  description?: string;
  ogType?: string;
  ogImage?: string;
  publishedDate?: string;
  tags?: string[];
}

const canonicalURL = new URL(Astro.url.pathname, Astro.site);
const {
  title = "./havu",
  description = "Inho Shin — Security Researcher",
  ogType = "website",
  ogImage,
  publishedDate,
  tags = [],
} = Astro.props;
---

<!doctype html>
<html lang="en" data-theme="dark">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="description" content={description} />
    <meta name="author" content="Inho Shin" />
    <link rel="canonical" href={canonicalURL.href} />
    <link rel="alternate" type="application/rss+xml" title="RSS" href="/rss.xml" />
    <link rel="icon" type="image/png" sizes="32x32" href="/icons/favicon-32x32.png" />
    <link rel="icon" type="image/png" sizes="16x16" href="/icons/favicon-16x16.png" />
    <link rel="apple-touch-icon" sizes="180x180" href="/icons/apple-touch-icon.png" />
    <link rel="manifest" href="/icons/site.webmanifest" />

    <!-- Open Graph -->
    <meta property="og:type" content={ogType} />
    <meta property="og:url" content={canonicalURL.href} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:site_name" content="kernel.re" />
    <meta property="og:locale" content="en_US" />
    {ogImage && <meta property="og:image" content={new URL(ogImage, Astro.site).href} />}
    {publishedDate && <meta property="article:published_time" content={publishedDate} />}
    {tags.map((tag) => <meta property="article:tag" content={tag} />)}

    <!-- Twitter Card -->
    <meta name="twitter:card" content={ogImage ? "summary_large_image" : "summary"} />
    <meta name="twitter:site" content="@havu0" />
    <meta name="twitter:creator" content="@havu0" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    {ogImage && <meta name="twitter:image" content={new URL(ogImage, Astro.site).href} />}

    <title>{title}</title>
    <script is:inline>
      const t = localStorage.getItem("theme") || "dark";
      document.documentElement.setAttribute("data-theme", t);
      document.addEventListener("DOMContentLoaded", () => {
        const btn = document.getElementById("theme-toggle");
        if (btn) btn.textContent = t === "dark" ? "\u2600\ufe0f" : "\ud83c\udf19";
      });
    </script>
  </head>
  <body>
    <nav>
      <a href="/" class="site-title">./havu</a>
      <div class="nav-right">
        <a href="/posts">Posts</a>
        <a href="/rss.xml">RSS</a>
        <button class="theme-toggle" id="theme-toggle" aria-label="Toggle theme"></button>
      </div>
    </nav>

    <main>
      <slot />
    </main>

    <footer>
      <p>&copy; {new Date().getFullYear()} havu</p>
    </footer>

    <script is:inline>
      document.getElementById("theme-toggle").addEventListener("click", function () {
        const html = document.documentElement;
        const current = html.getAttribute("data-theme");
        const next = current === "dark" ? "light" : "dark";
        html.setAttribute("data-theme", next);
        localStorage.setItem("theme", next);
        this.textContent = next === "dark" ? "\u2600\ufe0f" : "\ud83c\udf19";
        const frame = document.querySelector(".utterances-frame");
        if (frame) {
          frame.contentWindow.postMessage(
            { type: "set-theme", theme: next === "dark" ? "github-dark" : "github-light" },
            "https://utteranc.es"
          );
        }
      });
    </script>
  </body>
</html>
