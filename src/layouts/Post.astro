---
import Base from "./Base.astro";
import Utterances from "../components/Utterances.astro";

interface Props {
  frontmatter: {
    title: string;
    date: Date;
    description?: string;
    tags?: string[];
    categories?: string[];
  };
}

const { frontmatter } = Astro.props;
const date = new Date(frontmatter.date);
const dateStr = date.toISOString().slice(0, 10);
---

<Base title={`${frontmatter.title} | ./havu`} description={frontmatter.description}>
  <article>
    <div class="post-header">
      <h1>{frontmatter.title}</h1>
      <div class="post-meta">
        <time datetime={dateStr}>{dateStr}</time>
        {frontmatter.categories?.map((cat) => <span class="badge">{cat}</span>)}
        {frontmatter.tags?.map((tag) => <span class="badge">{tag}</span>)}
      </div>
    </div>
    <div class="post-content">
      <slot />
    </div>
  </article>
  <Utterances />
</Base>
